{
  "name": "romboiq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest run",
    "tester:check": "npm run type-check && npm run build && npm test",
    "coach:test": "tsx src/ai/testCoachAgent.ts",
    "coach:eval": "tsx scripts/runCoachEval.ts",
    "rag:build": "tsx scripts/buildCoachRagIndex.ts",
    "exercises:audit": "tsx scripts/auditExercises.ts",
    "type-check": "tsc --noEmit",
    "format": "biome format --write src api tests vite.config.ts package.json tsconfig.json biome.json",
    "lint": "biome lint src api tests vite.config.ts",
    "memory:test": "tsx src/ai/testMemoryUpdate.ts",
    "knowledge:test": "tsx src/ai/testKnowledgeExtraction.ts",
    "knowledge:build-up": "tsx src/ai/ingestBuildUpKnowledge.ts",
    "knowledge:defensive-transition": "tsx src/ai/ingestDefensiveTransition.ts",
    "knowledge:pressing": "tsx src/ai/ingestPressingKnowledge.ts",
    "knowledge:compactness": "tsx src/ai/ingestCompactnessKnowledge.ts",
    "observation:test": "tsx src/ai/testAddObservation.ts",
    "memory:build": "tsx src/ai/testBuildTacticalMemory.ts",
    "memory:consolidate": "tsx src/ai/testConsolidateMemory.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@react-pdf/renderer": "^4.1.6",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.19.1",
    "dexie": "^4.0.10",
    "dotenv": "^17.4.2",
    "openai": "^6.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.5",
    "three": "^0.172.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.22.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5"
  }
}
